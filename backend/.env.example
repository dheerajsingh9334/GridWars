# Backend environment variables for production (Render)
# ⚠️ DO NOT commit actual values - set these in Render dashboard only!

# Database connection
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# Frontend URL (update after deploying to Vercel)
CLIENT_URL=https://your-gridwars-frontend.vercel.app

# Environment
NODE_ENV=production

# Port (Render will use this)
PORT=5000
